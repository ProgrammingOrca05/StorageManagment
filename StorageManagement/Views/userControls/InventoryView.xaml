<Window x:Class="contact_list.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:contact_list"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>

        <Grid.ColumnDefinitions >

            <ColumnDefinition/>

            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#F5F7FB"/>

        <Border Grid.Column="1" Background="#E8F1FF"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Margin="60,49,0,0" TextWrapping="Wrap" Text="Name" VerticalAlignment="Top" Height="26" Width="117"/>
        <TextBox Name="person_name" Grid.Column="1" HorizontalAlignment="Left" Margin="57,80,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Height="28"/>
        <TextBlock Grid.Column="1" HorizontalAlignment="Left" Margin="63,113,0,0" TextWrapping="Wrap" Text="phone" VerticalAlignment="Top" Height="26" Width="117"/>
        <TextBox Name="person_phone" Grid.Column="1" HorizontalAlignment="Left" Margin="57,144,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Height="28" RenderTransformOrigin="0.53,-0.252"/>
        <Button Grid.Column="1" Content="Add" HorizontalAlignment="Left" Margin="57,177,0,0" VerticalAlignment="Top" Height="30" Width="120" Click="Button_Click"/>
        <TextBox Name="list1" HorizontalAlignment="Left" Margin="95,117,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="249" Height="307" AcceptsReturn="True"/>
        <TextBlock HorizontalAlignment="Left" Margin="95,94,0,0" TextWrapping="Wrap" Text="list of person" VerticalAlignment="Top" Height="26" Width="249"/>
        <TextBox Name="search_box" HorizontalAlignment="Center" Margin="0,21,0,0" VerticalAlignment="Top" Width="210" Height="31"/>
        <Button  Content="search" HorizontalAlignment="Left" Margin="95,56,0,0" VerticalAlignment="Top" Height="29" Width="105" Click="Button_Click_1"/>
        <TextBlock HorizontalAlignment="Left" Margin="95,0,0,0" TextWrapping="Wrap" Text="Search by name" VerticalAlignment="Top" Width="173" Height="16"/>
        <Button Content="edit" HorizontalAlignment="Left" Margin="60,221,0,0" VerticalAlignment="Top" Height="32" Width="114" Click="Button_Click_3" Grid.Column="1"/>


    </Grid>
</Window>